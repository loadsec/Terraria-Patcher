{
  "name": "terraria-patcher",
  "private": true,
  "version": "2.0.0",
  "author": "Louan Fontenele",
  "description": "A desktop tool for patching Terraria",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build:bridge": "node scripts/build-bridge-host.mjs",
    "build:bridge:win": "node scripts/build-bridge-host.mjs --runtime win-x64 --binary patcher-win.exe",
    "build:bridge:linux:musl": "node scripts/build-bridge-host.mjs --runtime linux-musl-x64 --binary patcher-linux",
    "build:bridge:linux:gnu": "node scripts/build-bridge-host.mjs --runtime linux-x64 --binary patcher-linux-gnu",
    "build:bridge:linux": "pnpm run build:bridge:linux:musl && pnpm run build:bridge:linux:gnu",
    "build:bridge:mac": "node scripts/build-bridge-host.mjs --runtime osx-x64 --binary patcher-mac",
    "prepare:mono": "node scripts/prepare-mono-toolchain.mjs",
    "build:plugin-loader-fna:auto": "node scripts/build-plugin-loader-fna.mjs",
    "build:plugin-loader-fna": "msbuild src/plugin-loader-fna/PluginLoader.FNA.csproj /p:Configuration=Release",
    "build:renderer": "electron-vite build",
    "build": "pnpm run build:bridge && pnpm run prepare:mono && pnpm run build:renderer",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build:bridge:win && pnpm run prepare:mono && pnpm run build:renderer && electron-builder --win",
    "build:mac": "pnpm run build:bridge:mac && pnpm run prepare:mono && pnpm run build:renderer && electron-builder --mac",
    "build:linux": "pnpm run build:plugin-loader-fna:auto && pnpm run build:bridge:linux && pnpm run prepare:mono && pnpm run build:renderer && electron-builder --linux",
    "lint": "eslint ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.575.0",
    "ms": "^2.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "rehype-raw": "^7.0.0",
    "sonner": "^2.0.7",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.8.9",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "shadcn": "^4.7.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.terraria-patcher",
    "productName": "Terraria Patcher",
    "npmRebuild": false,
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/patcher-bridge",
        "to": "patcher-bridge",
        "filter": [
          "patcher-win.exe",
          "patcher-mac",
          "patcher-linux",
          "patcher-linux-gnu"
        ]
      },
      {
        "from": "resources/plugins",
        "to": "patcher-resources/plugins",
        "filter": [
          "**/*",
          ".PluginLoaderTools/**/*"
        ]
      },
      {
        "from": "src/renderer/src/locales",
        "to": "patcher-locales",
        "filter": [
          "**/*.json"
        ]
      }
    ],
    "win": {
      "artifactName": "Terraria-Patcher-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "build/installer.nsh"
    },
    "mac": {
      "artifactName": "Terraria-Patcher-${version}-${arch}.${ext}",
      "identity": null,
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "artifactName": "Terraria-Patcher-${version}-${arch}.${ext}",
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "loadsec",
        "repo": "Terraria-Patcher"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      " ",
      "-",
      "a",
      "b",
      "c",
      "d",
      "e",
      "electron",
      "electron-winstaller",
      "esbuild",
      "h",
      "i",
      "l",
      "n",
      "o",
      "p",
      "r",
      "s",
      "t",
      "u",
      "v",
      "w"
    ]
  }
}
