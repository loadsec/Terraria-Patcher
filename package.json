{
  "name": "terraria-patcher",
  "private": true,
  "version": "1.1.4",
  "author": "Louan Fontenele",
  "description": "A desktop tool for patching Terraria",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build:bridge": "dotnet build src/main/bridge/TerrariaPatcherBridge.csproj -c Release",
    "build:plugin-loader-fna": "msbuild src/plugin-loader-fna/PluginLoader.FNA.csproj /p:Configuration=Release",
    "build": "pnpm run build:bridge && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "lint": "eslint ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-edge-js": "^40.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.3",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.575.0",
    "ms": "^2.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.terraria-patcher",
    "productName": "Terraria Patcher",
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/electron-edge-js/build/Release/*.node"
    ],
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "src/main/bridge/bin/Release",
        "to": "patcher-bridge",
        "filter": [
          "*.dll",
          "*.json"
        ]
      },
      {
        "from": "resources/plugins",
        "to": "patcher-resources/plugins",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "src/renderer/src/locales",
        "to": "patcher-locales",
        "filter": [
          "**/*.json"
        ]
      },
      {
        "from": "node_modules/electron-edge-js",
        "to": "patcher-edge-js",
        "filter": [
          "lib/**",
          "build/Release/edge_coreclr.node",
          "build/Release/edge_nativeclr.node",
          "build/lib/bootstrap/bin/Release/**",
          "tools/checkMono.js",
          "package.json"
        ]
      }
    ],
    "win": {
      "artifactName": "Terraria-Patcher-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "artifactName": "Terraria-Patcher-${version}-${arch}.${ext}",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "artifactName": "Terraria-Patcher-${version}-${arch}.${ext}",
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "loadsec",
        "repo": "Terraria-Patcher"
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      " ",
      "-",
      "a",
      "b",
      "c",
      "d",
      "e",
      "electron",
      "electron-edge-js",
      "electron-winstaller",
      "esbuild",
      "h",
      "i",
      "l",
      "n",
      "o",
      "p",
      "r",
      "s",
      "t",
      "u",
      "v",
      "w"
    ]
  }
}
