# -----------------------------------------------------------------------------
dist/
dist-ssr/
out/
release/
*.blockmap
latest*.yml

# TypeScript incremental build metadata
*.tsbuildinfo

# -----------------------------------------------------------------------------
# C# bridge build artifacts (Mono.Cecil / edge-js bridge)
# -----------------------------------------------------------------------------
src/main/bridge/obj/
src/main/bridge/bin/*
!src/main/bridge/bin/Release/
src/main/bridge/bin/Release/*
!src/main/bridge/bin/Release/*.dll
!src/main/bridge/bin/Release/*.json
src/main/bridge/bin/Release/*.pdb

# FNA plugin loader build artifacts
src/plugin-loader-fna/bin/
src/plugin-loader-fna/obj/

# -----------------------------------------------------------------------------
# Logs / coverage / caches
# -----------------------------------------------------------------------------
logs/
*.log
*.pid
*.seed
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.eslintcache
coverage/
.nyc_output/
.cache/

# -----------------------------------------------------------------------------
# Local environment / machine-specific files
# -----------------------------------------------------------------------------
*.local
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Temporary files / backups
# -----------------------------------------------------------------------------
tmp/
temp/
@/
*.tmp
*.temp
*.bak
*.orig

